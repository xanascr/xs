{
  "name": "xanascript",
  "version": "2.2.8",
  "description": "Programming language with Portuguese syntax, optimizing compiler, built-in ORM, and WebAssembly support",
  "type": "module",
  "workspaces": [
    "xs-site",
    "xs-vscode",
    "xs-examples"
  ],
  "bin": {
    "xs": "bin/xs.js"
  },
  "scripts": {
    "build": "node scripts/build-all.js",
    "test": "node test/lexer.test.js && node test/parser.test.js && node test/interpreter.test.js",
    "test:xs": "node bin/xs.js test test/completo_test.xs",
    "test:all": "node test/run.js && node bin/xs.js test test/completo_test.xs",
    "lint": "node bin/xs.js fmt --check src/",
    "clean": "rm -rf dist node_modules xs-site/node_modules xs-vscode/node_modules"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanascr/xs.git"
  },
  "keywords": [
    "xanascript",
    "language",
    "portuguese",
    "programming",
    "compiler",
    "wasm"
  ],
  "author": "flazo0",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/xanascr/xs/issues"
  },
  "homepage": "https://xanascript.xyz",
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "chokidar": "^4.0.0"
  },
  "files": [
    "src",
    "bin",
    "std",
    "llms.txt",
    "VERSION"
  ]
}
